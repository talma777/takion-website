    <script>
    function moverSelectorIdioma() {
        const selector = document.getElementById('select_idioma');
        const contenedorMobile = document.getElementById('contenedor_select_idioma_mobile');
        const contenedorPC = document.getElementById('li_contenedor_pc');

        if (window.innerWidth <= 1000) {
        // Mover a contenedor móvil si no está ya ahí
        if (selector.parentElement !== contenedorMobile) {
            contenedorMobile.appendChild(selector);
        }
        } else {
        // Mover a contenedor de PC si no está ya ahí
        if (selector.parentElement !== contenedorPC) {
            contenedorPC.appendChild(selector);
        }
        }
    }

    // Ejecuta al cargar la página y al cambiar el tamaño
    window.addEventListener('DOMContentLoaded', moverSelectorIdioma);
    window.addEventListener('resize', moverSelectorIdioma);
    </script>

